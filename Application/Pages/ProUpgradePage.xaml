<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.ProUpgradePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Nâng cấp PRO"
    BackgroundColor="#0D1B2A">

    <Shell.TitleView>
        <Label Text="🌟 Gói PRO"
               FontSize="18" FontAttributes="Bold"
               TextColor="White"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="16,20,16,32">

            <!-- ── Tiêu đề ── -->
            <Label Text="Mở khóa trải nghiệm du lịch đỉnh cao"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"
                   Margin="0,0,0,6" />

            <Label Text="So sánh Gói Cơ bản và Gói PRO"
                   FontSize="14"
                   TextColor="#90CAF9"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24" />

            <!-- ── Bảng so sánh ── -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,0,0,24">

                <!-- CỘT FREE -->
                <Border Grid.Column="0"
                        Padding="16"
                        BackgroundColor="#1A2A3A"
                        Stroke="#2A4A6A"
                        StrokeThickness="1.5">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="🆓" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Gói Cơ bản"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />
                        <Label Text="Miễn phí"
                               FontSize="22" FontAttributes="Bold"
                               TextColor="#90CAF9"
                               HorizontalOptions="Center" />

                        <BoxView Color="#2A4A6A" HeightRequest="1" Margin="0,4" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="✅ Khám phá POI" FontSize="13" TextColor="#B0BEC5" />
                            <Label Text="✅ Nghe thuyết minh (giới hạn)" FontSize="13" TextColor="#B0BEC5" />
                            <Label Text="✅ Quét QR (tối đa 5 lần/mã)" FontSize="13" TextColor="#B0BEC5" />
                            <Label Text="❌ Chỉ đường trực tiếp" FontSize="13" TextColor="#546E7A" />
                            <Label Text="❌ Nhật ký hành trình" FontSize="13" TextColor="#546E7A" />
                            <Label Text="❌ QR vô hạn" FontSize="13" TextColor="#546E7A" />
                        </VerticalStackLayout>

                        <Border Padding="12,10" BackgroundColor="#1E3A4A" Stroke="#00000000" Margin="0,8,0,0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Label Text="Đang sử dụng"
                                   FontSize="13" FontAttributes="Bold"
                                   TextColor="#78909C"
                                   HorizontalOptions="Center" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <!-- CỘT PRO -->
                <Border Grid.Column="1"
                        Padding="16"
                        BackgroundColor="#1A2E1A"
                        Stroke="#FFD700"
                        StrokeThickness="2">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="16" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#FFD700" Opacity="0.25" Offset="0,4" Radius="12" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="14">
                        <Label Text="🌟" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Gói PRO"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="#FFD700"
                               HorizontalOptions="Center" />
                        <Label Text="99.000đ/tháng"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center" />

                        <BoxView Color="#3A5A2A" HeightRequest="1" Margin="0,4" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="✅ Khám phá POI" FontSize="13" TextColor="#C8E6C9" />
                            <Label Text="✅ Thuyết minh VÔ HẠN" FontSize="13" TextColor="#C8E6C9" FontAttributes="Bold" />
                            <Label Text="✅ Quét QR VÔ HẠN" FontSize="13" TextColor="#C8E6C9" FontAttributes="Bold" />
                            <Label Text="✅ Chỉ đường trực tiếp" FontSize="13" TextColor="#A5D6A7" FontAttributes="Bold" />
                            <Label Text="✅ Nhật ký hành trình" FontSize="13" TextColor="#A5D6A7" FontAttributes="Bold" />
                            <Label Text="✅ Ưu tiên hỗ trợ" FontSize="13" TextColor="#C8E6C9" />
                        </VerticalStackLayout>

                        <Button x:Name="BtnUpgrade"
                                Text="Nâng Cấp Ngay"
                                BackgroundColor="#FFD700"
                                TextColor="#1A2E1A"
                                FontAttributes="Bold"
                                FontSize="14"
                                CornerRadius="10"
                                Margin="0,8,0,0"
                                Clicked="OnUpgradeNowClicked" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- ── Cam kết ── -->
            <Border Padding="16,12" BackgroundColor="#1A2A3A" Stroke="#2A4A6A">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="6">
                    <Label Text="🔒  Thanh toán an toàn  |  Hủy bất kỳ lúc nào"
                           FontSize="12" TextColor="#90CAF9"
                           HorizontalOptions="Center" />
                    <Label Text="Gói PRO có hiệu lực 30 ngày kể từ khi kích hoạt"
                           FontSize="12" TextColor="#78909C"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
