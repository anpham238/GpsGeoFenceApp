@startuml sequence-geofence-to-narration
title Geofence → Priority → Narration (luồng chính)
skinparam defaultFontSize 11

actor       User
participant "Geofence\nEngine"  as Geo
participant "EventGate"         as Gate
participant "NarrationHandler"  as H
participant "NarrationManager"  as Nar
participant "Audio/TTS"         as Audio
database    "API + DB"          as API

User -> Geo  : Di chuyển → Enter/Near POI
Geo  -> Gate : ShouldAccept(poiId, eventType)
note right of Gate : debounce + cooldown per (POI, device)

alt Gate từ chối
  Gate --> Geo : false → bỏ qua
else Gate chấp nhận
  Gate -> H   : PlayAsync(poi, eventType)
  H -> API    : GET /narration?poiId&lang (cache first)
  API --> H   : narrationText
  H -> Nar    : HandleAsync(announcement)
  note right of Nar
    Winner-only: nếu POI khác đang queue
    với PriorityLevel cao hơn → discard
    Nếu thắng → xóa losers khỏi queue
  end note
  alt POI bị loại (loser)
    Nar --> H : return (no-op)
  else POI thắng → phát
    alt AudioUrl có sẵn
      Nar -> Audio : PlayFileAsync(audioUrl)
    else TTS fallback
      Nar -> Audio : SpeakAsync(narrationText)
    end
    Audio --> Nar : Completed
    Nar -> API : POST /analytics/visit + /listen-duration
  end
end
@enduml
