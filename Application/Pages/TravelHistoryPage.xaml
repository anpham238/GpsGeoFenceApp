<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.TravelHistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Nhật ký hành trình"
    BackgroundColor="#F5F7FA">

    <Shell.TitleView>
        <Label Text="🗺️ Nhật ký hành trình"
               FontSize="17" FontAttributes="Bold"
               TextColor="#202124"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <Grid RowDefinitions="*,Auto">

        <maps:Map x:Name="HistoryMap"
                  Grid.Row="0"
                  MapType="Street"
                  IsShowingUser="True"
                  IsScrollEnabled="True"
                  IsZoomEnabled="True" />

        <!-- Loading overlay -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0"
              BackgroundColor="#80000000"
              IsVisible="True">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="True" Color="White" WidthRequest="40" HeightRequest="40" />
                <Label Text="Đang tải hành trình..." TextColor="White" FontSize="15" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

        <!-- Info bar ở dưới -->
        <Border Grid.Row="1"
                Padding="16,12"
                BackgroundColor="White"
                Stroke="#E6E6E6"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.1" Offset="0,-2" Radius="8" />
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label x:Name="LblPointCount"
                           Text="0 điểm GPS"
                           FontSize="15" FontAttributes="Bold"
                           TextColor="#202124" />
                    <Label x:Name="LblDateRange"
                           Text=""
                           FontSize="13" TextColor="#5F6368" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        Padding="10,6"
                        BackgroundColor="#FFEBEE"
                        Stroke="#00000000">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="6">
                        <BoxView Color="Red" WidthRequest="20" HeightRequest="4" VerticalOptions="Center" CornerRadius="2" />
                        <Label Text="Tuyến đường" FontSize="12" TextColor="#C62828" VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

    </Grid>
</ContentPage>
