<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.AreaPackSelectPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Chọn khu vực"
    BackgroundColor="#0D1B2A">

    <Shell.TitleView>
        <Label Text="CHỌN KHU VỰC"
               FontSize="17" FontAttributes="Bold"
               TextColor="White"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Subtitle -->
        <VerticalStackLayout Grid.Row="0" Padding="16,12,16,8" Spacing="4">
            <Label Text="Mở khóa nội dung theo khu vực bạn muốn"
                   FontSize="13" TextColor="#90CAF9"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- Search box -->
        <Border Grid.Row="1"
                Margin="16,0,16,12"
                Padding="12,0"
                BackgroundColor="#1A2A3A"
                Stroke="#2A4A6A"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="12" />
            </Border.StrokeShape>
            <SearchBar x:Name="SearchBox"
                       Placeholder="Tìm kiếm khu vực..."
                       PlaceholderColor="#546E7A"
                       TextColor="White"
                       BackgroundColor="Transparent"
                       TextChanged="OnSearchTextChanged" />
        </Border>

        <!-- Loading indicator -->
        <ActivityIndicator x:Name="LoadingIndicator"
                           Grid.Row="2"
                           IsRunning="True"
                           IsVisible="True"
                           Color="#29B6F6"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />

        <!-- Area list -->
        <CollectionView x:Name="AreaList"
                        Grid.Row="2"
                        IsVisible="False"
                        Margin="16,0,16,16">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Padding="16"
                            BackgroundColor="#1A2A3A"
                            Stroke="#2A4A6A"
                            StrokeThickness="1"
                            Margin="0,0,0,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">

                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding AreaName}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="White" />

                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding City}"
                                   FontSize="13" TextColor="#90CAF9" />

                            <Label Grid.Row="2" Grid.Column="0"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="#29B6F6">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="Giá: " TextColor="#B0BEC5" FontSize="13" />
                                        <Span Text="{Binding PriceDisplay}" TextColor="#29B6F6" FontAttributes="Bold" FontSize="14" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                    Text="MUA NGAY"
                                    BackgroundColor="#29B6F6"
                                    TextColor="#0D1B2A"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    CornerRadius="10"
                                    Padding="14,0"
                                    HeightRequest="44"
                                    VerticalOptions="Center"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnBuyAreaClicked" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Empty state -->
        <VerticalStackLayout x:Name="EmptyState"
                             Grid.Row="2"
                             IsVisible="False"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Label Text="🔍" FontSize="40" HorizontalOptions="Center" />
            <Label Text="Không tìm thấy khu vực"
                   FontSize="15" TextColor="#78909C"
                   HorizontalOptions="Center" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
