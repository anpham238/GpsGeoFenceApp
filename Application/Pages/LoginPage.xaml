<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Đăng nhập"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F4F6F8"> <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="0" VerticalOptions="Center">

            <Border Background="White"
                    StrokeThickness="0"
                    Padding="24,32"
                    Margin="0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.1" Offset="0,4" Radius="10" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="16">
                    <Label Text="Smart Tourism" FontSize="28" FontAttributes="Bold" TextColor="#1976D2" HorizontalOptions="Center" Margin="0,0,0,8" />
                    <Label Text="Khám phá thành phố theo cách của bạn" FontSize="14" TextColor="#666" HorizontalOptions="Center" Margin="0,0,0,24" />

                    <Label Text="Tên đăng nhập" FontSize="14" FontAttributes="Bold" TextColor="#333" />
                    <Border Background="#F9F9F9" Stroke="#E0E0E0" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Entry x:Name="UsernameEntry" Placeholder="Nhập tài khoản" Margin="8,0" ReturnType="Next" />
                    </Border>

                    <Label Text="Mật khẩu" FontSize="14" FontAttributes="Bold" TextColor="#333" Margin="0,8,0,0"/>
                    <Border Background="#F9F9F9" Stroke="#E0E0E0" StrokeThickness="1">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Entry x:Name="PasswordEntry" Placeholder="Nhập mật khẩu" Margin="8,0" IsPassword="True" ReturnType="Done" ReturnCommand="{Binding Source={x:Reference LoginBtn}, Path=Command}" />
                    </Border>

                    <Label x:Name="ErrorLabel" TextColor="#D32F2F" FontSize="13" IsVisible="False" HorizontalOptions="Center" Margin="0,8,0,0" />

                    <Button x:Name="LoginBtn" Text="ĐĂNG NHẬP" FontAttributes="Bold" BackgroundColor="#1976D2" TextColor="White" CornerRadius="8" HeightRequest="48" Margin="0,16,0,0" Clicked="OnLoginClicked" />
                    <ActivityIndicator x:Name="LoadingIndicator" IsRunning="False" IsVisible="False" HorizontalOptions="Center" Color="#1976D2" />
                </VerticalStackLayout>
            </Border>
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,16,0,0">
                <Label Text="Chưa có tài khoản?" VerticalOptions="Center" TextColor="#666" />
                <Label Text="Đăng ký ngay" TextColor="#1976D2" FontAttributes="Bold" VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterClicked" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
            <Button Text="Về bản đồ"
                    Clicked="OnBackToMapClicked"
                    Margin="0,12,0,0"
                    BackgroundColor="Transparent"
                    TextColor="#1976D2"
                    FontAttributes="Bold" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>