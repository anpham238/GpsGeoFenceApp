<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Đăng ký tài khoản">

    <ScrollView>
        <VerticalStackLayout Padding="32" Spacing="14" VerticalOptions="Center">

            <Label Text="Tạo tài khoản" FontSize="24" FontAttributes="Bold"
                   HorizontalOptions="Center" Margin="0,0,0,16" />

            <Label Text="Tên đăng nhập" FontSize="14" />
            <Entry x:Name="UsernameEntry" Placeholder="Tối thiểu 3 ký tự" ReturnType="Next" />

            <Label Text="Email" FontSize="14" />
            <Entry x:Name="MailEntry" Placeholder="example@email.com"
                   Keyboard="Email" ReturnType="Next" />

            <Label Text="Mật khẩu" FontSize="14" />
            <Entry x:Name="PasswordEntry" Placeholder="Tối thiểu 6 ký tự"
                   IsPassword="True" ReturnType="Next" />

            <Label Text="Xác nhận mật khẩu" FontSize="14" />
            <Entry x:Name="ConfirmEntry" Placeholder="Nhập lại mật khẩu"
                   IsPassword="True" ReturnType="Done" />

            <Label x:Name="ErrorLabel" TextColor="Red" FontSize="13"
                   IsVisible="False" HorizontalOptions="Center" />

            <Button x:Name="RegisterBtn"
                    Text="Đăng ký"
                    Clicked="OnRegisterClicked"
                    Margin="0,8,0,0"
                    HeightRequest="48" />

            <Button Text="Đã có tài khoản? Đăng nhập"
                    Clicked="OnBackToLoginClicked"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource Primary}" />

            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False" IsVisible="False"
                               HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>