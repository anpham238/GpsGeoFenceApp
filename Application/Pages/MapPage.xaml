<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="">
    <!-- Ẩn TitleView mặc định vì ta tự vẽ header trong Grid -->
    <Shell.TitleView>
        <ContentView />
    </Shell.TitleView>

    <Grid RowDefinitions="*" ColumnDefinitions="*">
        <maps:Map x:Name="MyMap"
                  MapType="Street"
                  IsShowingUser="False"
                  IsScrollEnabled="True"
                  IsZoomEnabled="True" />

        <!-- ═══════════════════════════════════════════════════
             HEADER PANEL (thay thế Shell.TitleView + LangBar cũ)
             ═══════════════════════════════════════════════════ -->
        <VerticalStackLayout Margin="12,10,12,0"
                             VerticalOptions="Start"
                             Spacing="6"
                             ZIndex="8">

            <!-- ROW 1: Thanh "Tất cả địa điểm" + Avatar user -->
            <Border Padding="10,0"
                    BackgroundColor="White"
                    Stroke="#E6E6E6"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.12" Offset="0,2" Radius="8" />
                </Border.Shadow>

                <Grid ColumnDefinitions="*,Auto" HeightRequest="48">
                    <!-- Picker địa điểm -->
                    <Picker x:Name="TourPicker"
                            Grid.Column="0"
                            Title="🗺 Tất cả địa điểm"
                            TextColor="#1F1F1F"
                            TitleColor="#5F6368"
                            FontSize="15"
                            BackgroundColor="Transparent"
                            VerticalOptions="Center"
                            SelectedIndexChanged="OnTourSelected" />

                    <!-- Avatar user (hình tròn) -->
                    <Border Grid.Column="1"
                            x:Name="AvatarBorder"
                            WidthRequest="36"
                            HeightRequest="36"
                            BackgroundColor="#5C6BC0"
                            Stroke="Transparent"
                            Margin="0,0,4,0"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTopLoginClicked" />
                        </Border.GestureRecognizers>

                        <Grid>
                            <Image x:Name="ImgAvatar" Aspect="AspectFill" IsVisible="False" WidthRequest="36" HeightRequest="36">
                                <Image.Clip>
                                    <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18" />
                                </Image.Clip>
                            </Image>
                            <Label x:Name="AvatarLabel" Text="?" TextColor="White" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ROW 2: Hàng cờ ngôn ngữ + nút QR tròn ở góc phải -->
            <Grid ColumnDefinitions="*,Auto">
                <!-- Cờ ngôn ngữ -->
                <Border Grid.Column="0"
                        Padding="10,8"
                        BackgroundColor="White"
                        Stroke="#E6E6E6"
                        StrokeThickness="1"
                        Margin="0,0,8,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Offset="0,2" Radius="6" />
                    </Border.Shadow>
                    <HorizontalStackLayout x:Name="LangBar" Spacing="6">
                        <Border x:Name="BtnVi" Padding="8,4" Background="#1976D2" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇻🇳" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="vi-VN" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnEn" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇺🇸" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="en-US" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnJa" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇯🇵" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ja-JP" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnKo" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇰🇷" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ko-KR" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnDe" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇩🇪" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="de-DE" />
                            </Border.GestureRecognizers>
                        </Border>
                    </HorizontalStackLayout>
                </Border>

                <!-- Nút QR hình tròn nhỏ -->
                <Border Grid.Column="1"
                        WidthRequest="46"
                        HeightRequest="46"
                        BackgroundColor="White"
                        Stroke="#E6E6E6"
                        StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="23" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.14" Offset="0,2" Radius="6" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnQrButtonClicked" />
                    </Border.GestureRecognizers>
                    <!-- Icon QR bằng Path SVG -->
                    <Grid HorizontalOptions="Center" VerticalOptions="Center"
                          WidthRequest="26" HeightRequest="26">
                        <!-- Ô trên trái -->
                        <Path Data="M2 2 H9 V9 H2 Z M3 3 H8 V8 H3 Z M4 4 H7 V7 H4 Z"
                              Fill="#3F3F3F"
                              HorizontalOptions="Start"
                              VerticalOptions="Start" />
                        <!-- Ô trên phải -->
                        <Path Data="M15 2 H22 V9 H15 Z M16 3 H21 V8 H16 Z M17 4 H20 V7 H17 Z"
                              Fill="#3F3F3F"
                              HorizontalOptions="Start"
                              VerticalOptions="Start" />
                        <!-- Ô dưới trái -->
                        <Path Data="M2 15 H9 V22 H2 Z M3 16 H8 V21 H3 Z M4 17 H7 V20 H4 Z"
                              Fill="#3F3F3F"
                              HorizontalOptions="Start"
                              VerticalOptions="Start" />
                        <!-- Chấm dữ liệu giữa -->
                        <Path Data="M11 2 H13 V4 H11 Z M11 6 H13 V8 H11 Z M11 11 H13 V13 H11 Z M6 11 H8 V13 H6 Z M2 11 H4 V13 H2 Z M15 11 H17 V13 H15 Z M19 11 H22 V13 H19 Z M15 15 H17 V17 H15 Z M19 15 H21 V17 H19 Z M11 15 H13 V17 H11 Z M15 19 H17 V22 H15 Z M19 19 H22 V22 H19 Z M11 19 H13 V22 H11 Z"
                              Fill="#3F3F3F"
                              HorizontalOptions="Start"
                              VerticalOptions="Start" />
                    </Grid>
                </Border>
            </Grid>
        </VerticalStackLayout>
        <!-- ═══════════════ KẾT THÚC HEADER ═══════════════ -->

        <!-- Nút định vị + zoom (giữ nguyên) -->
        <VerticalStackLayout Grid.Row="0"
                             HorizontalOptions="End"
                             VerticalOptions="Center"
                             Margin="0,130,12,0"
                             Spacing="10"
                             ZIndex="7">
            <Border Background="White" Stroke="#E6E6E6" StrokeThickness="1" WidthRequest="46" HeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="23" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.16" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <Grid BackgroundColor="Transparent">
                    <Path Data="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"
                          Fill="#1A73E8"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="23"
                          HeightRequest="23" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocateMeClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <Border Background="White" Stroke="#E6E6E6" StrokeThickness="1" WidthRequest="46" HeightRequest="94">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.16" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <Grid RowDefinitions="*,1,*">
                    <Button Grid.Row="0" Text="+" FontSize="20" TextColor="#3C4043" BackgroundColor="Transparent" Padding="0" Clicked="OnZoomInClicked" />
                    <BoxView Grid.Row="1" Color="#ECECEC" />
                    <Button Grid.Row="2" Text="−" FontSize="20" TextColor="#3C4043" BackgroundColor="Transparent" Padding="0" Clicked="OnZoomOutClicked" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- Bottom Sheet (giữ nguyên) -->
        <Border x:Name="BottomSheet" Padding="0" Background="Transparent" VerticalOptions="End" ZIndex="10">
            <Border Padding="16,8,16,14" Background="White" Stroke="#E6E6E6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18,18,0,0" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.12" Offset="0,-2" Radius="10" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                    <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="0,6,0,8">
                        <BoxView HeightRequest="4" WidthRequest="46" HorizontalOptions="Center" BackgroundColor="#D0D0D0" CornerRadius="2" />
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="BottomSheet_PanUpdated" />
                            <TapGestureRecognizer Tapped="BottomSheet_TapHeader" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="2">
                        <Label x:Name="DetailName" FontSize="17" FontAttributes="Bold" TextColor="#202124" />
                        <Label x:Name="DetailDesc" FontSize="13" TextColor="#5F6368" MaxLines="3" LineBreakMode="TailTruncation" />
                        <Label x:Name="DetailCoord" FontSize="12" TextColor="#80868B" />
                        <Label x:Name="DetailRadius" FontSize="12" TextColor="#80868B" />
                    </VerticalStackLayout>

                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#F2F4F8" Stroke="#00000000" Margin="0,8,0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Grid HeightRequest="170">
                            <CarouselView x:Name="PoiImageCarousel"
                                          IndicatorView="PoiImageIndicator"
                                          IsVisible="False"
                                          Loop="False"
                                          HeightRequest="170">
                                <CarouselView.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding .}" Aspect="AspectFill" HeightRequest="170" />
                                    </DataTemplate>
                                </CarouselView.ItemTemplate>
                            </CarouselView>
                            <IndicatorView x:Name="PoiImageIndicator"
                                           IndicatorColor="#80FFFFFF"
                                           SelectedIndicatorColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="End"
                                           Margin="0,0,0,6"
                                           IsVisible="False" />
                            <Image x:Name="PoiImage" HeightRequest="170" Aspect="AspectFill" />
                        </Grid>
                    </Border>

                    <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="6">
                        <Label Text="Liên kết:" FontSize="12" TextColor="#5F6368" />
                        <Label x:Name="LblPoiLink" FontSize="12" TextColor="#1A73E8" LineBreakMode="TailTruncation" MaxLines="1" />
                    </HorizontalStackLayout>

                    <Button x:Name="BtnOpenInMaps"
                            Grid.Row="4"
                            Grid.ColumnSpan="2"
                            Text="Mở Google Maps"
                            FontSize="13"
                            Padding="12,9"
                            BackgroundColor="#1A73E8"
                            TextColor="White"
                            CornerRadius="10"
                            Margin="0,10,0,0" />
                </Grid>
            </Border>
        </Border>
    </Grid>
</ContentPage>
