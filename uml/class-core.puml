@startuml class-core
title Class Diagram — GpsGeoFenceApp Core
skinparam classAttributeIconSize 0
hide empty members
skinparam defaultFontSize 10

package "Mobile App" #f0f4ff {

  class MapPage {
    +OnGeofenceEvent(poi, type)
    +StartTracking()
  }

  interface ILocationService   { +StartTracking() / StopTracking() }
  interface IGeofenceService   { +RegisterAsync(pois) }
  class AndroidLocationService
  class AndroidGeofenceService
  ILocationService  <|.. AndroidLocationService
  IGeofenceService  <|.. AndroidGeofenceService

  class GeofenceEventGate <<static>> {
    +ShouldAccept(poiId, eventType,\n  debounceSec, cooldownSec) : bool
  }

  class PoiPriorityResolver {
    +Resolve(candidates, nowUtc) : List<QueueItem>
    +ResolveConflictWinner(candidates) : QueueItem?
  }

  class PoiCandidate {
    +PoiId, PriorityLevel, DistanceMeters
    +IsTapped, AllowInterrupt, TourSortOrder?
  }

  class NarrationQueueItem {
    +PoiId, FinalPriorityScore
    +AllowInterrupt, IsTapBoosted
  }

  enum NarrationState { Idle / Queued / Playing / Interrupted / Completed }

  class NarrationQueueManager {
    +CurrentState : NarrationState
    +EnqueueConflictResolved(winner)
    +TryInterrupt(incoming) : bool
    +CompleteCurrentAndPlayNext()
  }

  class PoiNarrationHandler {
    -DebounceMs = 250
    +PlayAsync(poi, evType, ct)
  }

  class NarrationManager {
    +HandleAsync(announcement, ct)
    +Stop()
    -IsDuplicate(ann, 2s) : bool
    -WorkerLoopAsync()
  }

  interface IAudioPlayer { +PlayFileAsync(url, ct) / Stop() }
  class AndroidAudioPlayer
  IAudioPlayer <|.. AndroidAudioPlayer

  class PoiNarrationCache {
    +GetAsync(poiId, ev, lang) : string?
    +UpsertAsync(...)
  }

  class PoiSyncService  { +SyncAsync() }
  class PoiDatabase     { +SavePoisAsync() / LoadPoisAsync() }
  class AnalyticsClient {
    +LogVisitAsync(poiId, action)
    +LogListenDurationAsync(poiId, dur)
  }
}

package "Backend API" #fff4e0 {

  class PoiNarrationRateLimiter {
    -MaxConcurrentPerPoi = 10
    -SpreadDelayMs = 80
    +AcquireAsync(poiId, ct)
    +Release(poiId)
  }

  class DevicePresenceService {
    +OnlineCount : int
    +TotalConnectionCount : int
    +MarkConnected(deviceId, connId)
    +MarkDisconnected(deviceId, connId)
  }

  class AppBuildService {
    +TriggerBuildAsync()
    +Status : AppBuildStatus
  }

  class Poi {
    +Id, Name, Latitude, Longitude
    +RadiusMeters = 120
    +PriorityLevel = 0
    +AudioSourceMode = "AUDIO_FIRST"
  }

  class AppDb {
    +Pois, PoiLanguages, PoiMedia
    +Users, GuestDevices
    +PoiTickets, WebNarrationUsages
    +Analytics_Visit, Analytics_ListenDuration
  }
}

' Key relations
MapPage --> GeofenceEventGate
MapPage --> PoiPriorityResolver
MapPage --> NarrationQueueManager
MapPage --> PoiNarrationHandler
PoiPriorityResolver ..> NarrationQueueItem
NarrationQueueManager o-- NarrationQueueItem
NarrationQueueManager --> NarrationState
PoiNarrationHandler --> NarrationManager
PoiNarrationHandler --> PoiNarrationCache
NarrationManager --> IAudioPlayer
AppDb --> Poi
@enduml
