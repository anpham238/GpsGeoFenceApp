@startuml sequence-web-qr-landing
title Web QR Landing — Quét QR → Nghe / Tải App
skinparam defaultFontSize 11

actor       "Du khách"    as U
participant "Browser JS"  as JS
participant "API"         as API
participant "BuildService" as Build
database    "DB"          as DB

U  -> JS  : Quét QR → mở /p/{poiId}
JS -> API : GET /api/public/poi/{id}?lang=vi-VN
API -> DB : SELECT Poi + PoiLanguage + PoiMedia
DB --> API : payload
API --> JS : { name, audioUrl, narrationText }

U  -> JS  : Click "Phát thuyết minh"
JS -> JS  : play() ngay từ cache (user gesture)
JS -> API : POST /api/public/poi/{id}/play-narration\n{ deviceKey, lang }
API -> DB : SELECT/UPDATE WebNarrationUsage
alt PlayCount >= 3
  API --> JS : { allowed:false }
  JS --> U   : Toast "Hết lượt → Tải app"
else
  API --> JS : { allowed:true, playCount }
  JS -> JS   : Cập nhật quota bar
end

U  -> JS  : Click "Tải ứng dụng"
JS -> API : GET /api/public/app/build/status
alt APK sẵn sàng
  JS --> U : Redirect download APK
else Cần build
  JS -> API : POST /api/public/app/build
  API -> Build : TriggerBuildAsync()
  loop Poll 3s đến khi done
    JS -> API  : GET /build/status
    API -> Build : GetBuildStatus()
    Build --> JS : { status, logTail }
  end
  JS --> U : Redirect download APK
end

U  -> JS  : Click "Mở ứng dụng"
JS -> JS  : Deep link: smarttourism://poi/{id}
@enduml
