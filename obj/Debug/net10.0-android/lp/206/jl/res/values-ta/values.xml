<string name="common_google_play_services_enable_button" msgid="2523291102206661146">இயக்கு</string>
<string name="common_google_play_services_enable_text" msgid="227660514972886228">%1$s ஆப்ஸுக்கு Google Play சேவைகள் இயக்கப்பட்டிருக்க வேண்டும்.</string>
<string name="common_google_play_services_enable_title" msgid="5122002158466380389">Google Play சேவைகளை இயக்கவும்</string>
<string name="common_google_play_services_install_button" msgid="7153882981874058840">நிறுவு</string>
<string name="common_google_play_services_install_text">%1$s ஆப்ஸைத் தொடர்ந்து பயன்படுத்த Google Play சேவைகளை நிறுவுங்கள்.</string>
<string name="common_google_play_services_install_title" msgid="7215213145546190223">Google Play சேவைகளை நிறுவுதல்</string>
<string name="common_google_play_services_notification_channel_name">கிடைக்கும் Google Play சேவைகள்</string>
<string name="common_google_play_services_notification_ticker">Google Play சேவைகள் பிழை</string>
<string name="common_google_play_services_signin_required_text" msgid="9053896323427875356">%1$s ஆப்ஸால் Google Play சேவைகளுடன் இணைக்க முடியவில்லை. உங்கள் Google கணக்கில் உள்நுழையவும்.</string>
<string name="common_google_play_services_signin_required_title">உள்நுழைவு அவசியம்</string>
<string name="common_google_play_services_try_again_text">%1$s ஆப்ஸால் Google Play சேவைகளுடன் இணைக்க முடியவில்லை. மீண்டும் முயலவும்.</string>
<string name="common_google_play_services_try_again_title">மீண்டும் முயலவும்</string>
<string name="common_google_play_services_unsupported_text">உங்கள் சாதனம் Google Play சேவைகளை ஆதரிக்காததால் %1$s ஆப்ஸைப் பயன்படுத்த முடியாது. ஆதரிக்கப்படும் சாதனத்தைப் பயன்படுத்தவும்.</string>
<string name="common_google_play_services_unsupported_title">சாதனம் இணக்கமானதாக இல்லை</string>
<string name="common_google_play_services_update_button" msgid="6556509956452265614">புதுப்பி</string>
<string name="common_google_play_services_update_text" msgid="9053896323427875356">%1$s ஆப்ஸைப் பயன்படுத்த Google Play சேவைகளைப் புதுப்பியுங்கள்.</string>
<string name="common_google_play_services_update_title" msgid="6006316683626838685">Google Play சேவைகளைப் புதுப்பிக்கவும்</string>
<string name="common_google_play_services_updating_client_title">Google Play சேவைகளைப் புதுப்பிக்கிறது</string>
<string name="common_google_play_services_updating_text">Google Play சேவைகள் புதுப்பிக்கப்பட்டதும் %1$s ஆப்ஸ் கிடைக்கும்.</string>
<string name="common_google_play_services_wear_update_text">%1$s பயன்படுத்த Google Play சேவைகளைப் புதுப்பிக்கவும்.</string>
