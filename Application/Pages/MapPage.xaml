<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Bản đồ &amp; POI">

    <!-- Chỉ còn Map + BottomSheet kéo từ dưới -->
    <Grid RowDefinitions="*" ColumnDefinitions="*">

        <!-- Map -->
        <maps:Map x:Name="MyMap"
                  MapType="Street"
                  IsShowingUser="False"
                  IsScrollEnabled="True"
                  IsZoomEnabled="True" />

        <!-- Bottom Sheet -->
        <Border x:Name="BottomSheet"
                Padding="0"
                Background="Transparent"
                VerticalOptions="End"
                ZIndex="10">
            <Border Padding="16,10,16,16"
                    Background="White"
                    Stroke="#E0E0E0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16,16,0,0"/>
                </Border.StrokeShape>

                <!-- Thanh kéo -> Thông tin -> Ảnh -> Link -> Nút GG Maps -->
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">

                    <!-- Thanh kéo -->
                    <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="0,6,0,8">
                        <BoxView HeightRequest="4" WidthRequest="48"
                                 HorizontalOptions="Center"
                                 BackgroundColor="#CCCCCC"
                                 CornerRadius="2"/>
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="BottomSheet_PanUpdated"/>
                            <TapGestureRecognizer Tapped="BottomSheet_TapHeader"/>
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Thông tin POI (trên cùng) -->
                    <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="2">
                        <Label x:Name="DetailName"
                               FontSize="18" FontAttributes="Bold"
                               TextColor="#0D47A1"/>
                        <Label x:Name="DetailDesc"
                               FontSize="14" TextColor="#444" />
                        <Label x:Name="DetailCoord"
                               FontSize="12" TextColor="#888"/>
                        <Label x:Name="DetailRadius"
                               FontSize="12" TextColor="#888"/>
                    </VerticalStackLayout>

                    <!-- Ảnh POI (giữa) -->
                    <Border Grid.Row="2" Grid.ColumnSpan="2"
                            Background="#00000000" Stroke="#00000000"
                            Margin="0,8,0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Image x:Name="DetailImage"
                               HeightRequest="180"
                               Aspect="AspectFill"
                               BackgroundColor="#EEE"/>
                    </Border>

                    <!-- Link -->
                    <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="8">
                        <Label Text="Link:" FontSize="12" TextColor="#666"/>
                        <Label x:Name="LblPoiLink"
                               FontSize="12" TextColor="#1976D2"
                               LineBreakMode="TailTruncation" MaxLines="1"/>
                    </HorizontalStackLayout>

                    <!-- Nút mở Google Maps -->
                    <Button x:Name="BtnOpenInMaps"
                            Grid.Row="4" Grid.ColumnSpan="2"
                            Text="🗺 Mở Google Maps"
                            FontSize="13"
                            Padding="12,8"
                            BackgroundColor="#1976D2" TextColor="White"
                            CornerRadius="8" Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Border>

    </Grid>
</ContentPage>