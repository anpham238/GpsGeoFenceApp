<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Bản đồ &amp; POI">

    <Shell.TitleView>
        <Grid ColumnDefinitions="*, Auto" Padding="0,0,16,0">
            <Label x:Name="TopTitle" Text="Khách vãng lai" VerticalOptions="Center" FontSize="16" FontAttributes="Bold" TextColor="#555" />
            <Button x:Name="BtnTopLogin" Grid.Column="1" Text="Đăng nhập" BackgroundColor="Transparent" TextColor="#1976D2" FontAttributes="Bold" Clicked="OnTopLoginClicked" Padding="0" />
        </Grid>
    </Shell.TitleView>

    <Grid RowDefinitions="*" ColumnDefinitions="*">

        <Border Grid.Row="0"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="16,16,0,0"
                WidthRequest="48"
                HeightRequest="48"
                Background="White"
                Stroke="#E0E0E0"
                StrokeThickness="1"
                ZIndex="5">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.2" Offset="0,2" Radius="4" />
            </Border.Shadow>

            <Grid BackgroundColor="Transparent">
                <Label Text="☰" 
                       InputTransparent="True" 
                       FontSize="24" 
                       TextColor="#333333" 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center" 
                       Margin="0,0,0,2"/>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMenuTapped" />
                </Grid.GestureRecognizers>
            </Grid>
        </Border>

        <maps:Map x:Name="MyMap"
                  MapType="Street"
                  IsShowingUser="False"
                  IsScrollEnabled="True"
                  IsZoomEnabled="True" />

        <HorizontalStackLayout x:Name="LangBar" Grid.Row="0" HorizontalOptions="End" VerticalOptions="Start" Margin="0,8,8,0" Spacing="4" ZIndex="5">
            <Border x:Name="BtnVi" Padding="8,4" Background="#1976D2" Stroke="#00000000">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="🇻🇳" FontSize="16" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="vi-VN" />
                </Border.GestureRecognizers>
            </Border>
            <Border x:Name="BtnEn" Padding="8,4" Background="#333333" Stroke="#00000000">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="🇺🇸" FontSize="16" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="en-US" />
                </Border.GestureRecognizers>
            </Border>
            <Border x:Name="BtnJa" Padding="8,4" Background="#333333" Stroke="#00000000">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="🇯🇵" FontSize="16" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ja-JP" />
                </Border.GestureRecognizers>
            </Border>
            <Border x:Name="BtnKo" Padding="8,4" Background="#333333" Stroke="#00000000">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="🇰🇷" FontSize="16" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ko-KR" />
                </Border.GestureRecognizers>
            </Border>
            <Border x:Name="BtnDe" Padding="8,4" Background="#333333" Stroke="#00000000">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="6" />
                </Border.StrokeShape>
                <Label Text="🇩🇪" FontSize="16" />
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="de-DE" />
                </Border.GestureRecognizers>
            </Border>
        </HorizontalStackLayout>

        <VerticalStackLayout Grid.Row="0" HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,16,0" Spacing="16" ZIndex="5">
            <Border Background="White" Stroke="#E0E0E0" StrokeThickness="1" WidthRequest="48" HeightRequest="48">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.2" Offset="0,2" Radius="4" />
                </Border.Shadow>
                <Grid BackgroundColor="Transparent">
                    <Path Data="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"
                          Fill="#1976D2" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="24" HeightRequest="24" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocateMeClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <Border Background="White" Stroke="#E0E0E0" StrokeThickness="1" WidthRequest="44" HeightRequest="92">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.2" Offset="0,2" Radius="4" />
                </Border.Shadow>
                <Grid RowDefinitions="*,1,*">
                    <Button Grid.Row="0" Text="+" FontSize="22" TextColor="#555555" BackgroundColor="Transparent" Padding="0" Clicked="OnZoomInClicked" />
                    <BoxView Grid.Row="1" Color="#EEEEEE" />
                    <Button Grid.Row="2" Text="-" FontSize="26" TextColor="#555555" BackgroundColor="Transparent" Padding="0" Margin="0,0,0,2" Clicked="OnZoomOutClicked" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <Border x:Name="BottomSheet" Padding="0" Background="Transparent" VerticalOptions="End" ZIndex="10">
            <Border Padding="16,10,16,16" Background="White" Stroke="#E0E0E0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16,16,0,0"/>
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                    <Grid Grid.Row="0" Grid.ColumnSpan="2" Padding="0,6,0,8">
                        <BoxView HeightRequest="4" WidthRequest="48" HorizontalOptions="Center" BackgroundColor="#CCCCCC" CornerRadius="2"/>
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="BottomSheet_PanUpdated"/>
                            <TapGestureRecognizer Tapped="BottomSheet_TapHeader"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                    <VerticalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="2">
                        <Label x:Name="DetailName" FontSize="18" FontAttributes="Bold" TextColor="#0D47A1"/>
                        <Label x:Name="DetailDesc" FontSize="14" TextColor="#444"/>
                        <Label x:Name="DetailCoord" FontSize="12" TextColor="#888"/>
                        <Label x:Name="DetailRadius" FontSize="12" TextColor="#888"/>
                    </VerticalStackLayout>
                    <Border Grid.Row="2" Grid.ColumnSpan="2" Background="#00000000" Stroke="#00000000" Margin="0,8,0,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10"/>
                        </Border.StrokeShape>
                        <Image x:Name="PoiImage" HeightRequest="180" Aspect="AspectFill" BackgroundColor="#EEE"/>
                    </Border>
                    <HorizontalStackLayout Grid.Row="3" Grid.ColumnSpan="2" Spacing="8">
                        <Label Text="Link:" FontSize="12" TextColor="#666"/>
                        <Label x:Name="LblPoiLink" FontSize="12" TextColor="#1976D2" LineBreakMode="TailTruncation" MaxLines="1"/>
                    </HorizontalStackLayout>
                    <Button x:Name="BtnOpenInMaps" Grid.Row="4" Grid.ColumnSpan="2" Text="🗺 Mở Google Maps" FontSize="13" Padding="12,8" BackgroundColor="#1976D2" TextColor="White" CornerRadius="8" Margin="0,12,0,0"/>
                </Grid>
            </Border>
        </Border>

    </Grid>
</ContentPage>