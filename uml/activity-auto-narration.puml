@startuml activity-auto-narration
title Activity — Auto Narration Flow
skinparam defaultFontSize 11

start
:Mở MapPage → xin quyền vị trí;
if (Quyền OK?) then (Không)
  :Hiện thông báo; stop
endif
:Sync POI từ API → Đăng ký Geofence → Start GPS;

while (App chạy?) is (Có)
  :Nhận vị trí → Geofence detect ENTER/NEAR;
  if (Có POI?) then (Không)
    -> tiếp tục;
  endif
  :GeofenceEventGate (debounce + cooldown per-POI);
  if (Gate OK?) then (Không)
    -> bỏ qua;
  endif
  :NarrationHandler.PlayAsync() (debounce 250ms);
  :Fetch narrationText (Cache → API → Cache);
  :NarrationManager.HandleAsync();
  if (Queue có POI khác ưu tiên cao hơn?) then (Có)
    :Loại bỏ POI này (loser); -> tiếp tục;
  endif
  :Xóa losers khỏi queue, thêm winner;
  if (AudioUrl?) then (Có)
    :PlayFileAsync(audioUrl);
  else
    :TTS SpeakAsync(text);
  endif
  :Log Analytics;
endwhile (Không)

:Dừng tracking; stop
@enduml
