<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.PaymentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Thanh toán"
    BackgroundColor="#0D1B2A">

    <Shell.TitleView>
        <Label Text="THANH TOÁN"
               FontSize="17" FontAttributes="Bold"
               TextColor="White"
               VerticalOptions="Center"
               HorizontalOptions="Center" />
    </Shell.TitleView>

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="16,20,16,32">

            <!-- Tóm tắt gói mua -->
            <Border Padding="18"
                    BackgroundColor="#1A2A3A"
                    Stroke="#2A4A6A"
                    StrokeThickness="1.5"
                    Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">

                    <Label Text="Chi tiết đơn hàng"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="#90CAF9" />

                    <BoxView Color="#2A4A6A" HeightRequest="1" />

                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="12">

                        <Label Grid.Row="0" Grid.Column="0" Text="Gói đang mua:"
                               FontSize="13" TextColor="#78909C" VerticalOptions="Center" />
                        <Label Grid.Row="0" Grid.Column="1" x:Name="LblProductName"
                               FontSize="14" FontAttributes="Bold" TextColor="White" VerticalOptions="Center" />

                        <Label Grid.Row="1" Grid.Column="0" x:Name="LblAreaLabel"
                               Text="Khu vực:" FontSize="13" TextColor="#78909C" VerticalOptions="Center" />
                        <Label Grid.Row="1" Grid.Column="1" x:Name="LblAreaName"
                               FontSize="13" TextColor="White" VerticalOptions="Center" />

                        <Label Grid.Row="2" Grid.Column="0" Text="Số tiền:"
                               FontSize="13" TextColor="#78909C" VerticalOptions="Center" />
                        <Label Grid.Row="2" Grid.Column="1" x:Name="LblPrice"
                               FontSize="16" FontAttributes="Bold" TextColor="#FFD700" VerticalOptions="Center" />

                        <Label Grid.Row="3" Grid.Column="0" Text="Thời hạn:"
                               FontSize="13" TextColor="#78909C" VerticalOptions="Center" />
                        <Label Grid.Row="3" Grid.Column="1" x:Name="LblDuration"
                               FontSize="13" TextColor="White" VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Quyền lợi PRO (ẩn mặc định) -->
            <Border x:Name="ProBenefitsPanel"
                    IsVisible="False"
                    Padding="16"
                    BackgroundColor="#1A2E1A"
                    Stroke="#FFD700"
                    StrokeThickness="1"
                    Margin="0,0,0,16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Quyền lợi PRO:" FontSize="13" FontAttributes="Bold" TextColor="#FFD700" />
                    <Label Text="✅ Mở khóa toàn bộ POI" FontSize="13" TextColor="#C8E6C9" />
                    <Label Text="✅ Không giới hạn narration" FontSize="13" TextColor="#C8E6C9" />
                    <Label Text="✅ Không giới hạn QR" FontSize="13" TextColor="#C8E6C9" />
                    <Label Text="✅ Toàn bộ ngôn ngữ" FontSize="13" TextColor="#C8E6C9" />
                    <Label Text="✅ Offline / tính năng PRO" FontSize="13" TextColor="#A5D6A7" FontAttributes="Bold" />
                </VerticalStackLayout>
            </Border>

            <!-- Phương thức thanh toán -->
            <Border Padding="16"
                    BackgroundColor="#1A2A3A"
                    Stroke="#2A4A6A"
                    StrokeThickness="1.5"
                    Margin="0,0,0,20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Phương thức thanh toán"
                           FontSize="14" FontAttributes="Bold"
                           TextColor="#90CAF9" />
                    <BoxView Color="#2A4A6A" HeightRequest="1" />

                    <!-- Ví điện tử -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <RadioButton x:Name="RadioWallet" Grid.Column="0"
                                     IsChecked="True"
                                     Value="WALLET"
                                     CheckedChanged="OnPaymentMethodChanged" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="💳 Ví điện tử" FontSize="14" TextColor="White" />
                            <Label Text="Momo, ZaloPay, VNPay..." FontSize="12" TextColor="#78909C" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Thẻ ngân hàng -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <RadioButton x:Name="RadioBank" Grid.Column="0"
                                     Value="BANK"
                                     CheckedChanged="OnPaymentMethodChanged" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="🏦 Thẻ ngân hàng" FontSize="14" TextColor="White" />
                            <Label Text="ATM, Visa, Mastercard..." FontSize="12" TextColor="#78909C" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Mã thanh toán -->
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <RadioButton x:Name="RadioCode" Grid.Column="0"
                                     Value="CODE"
                                     CheckedChanged="OnPaymentMethodChanged" />
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                            <Label Text="🔑 Mã thanh toán khác" FontSize="14" TextColor="White" />
                            <Label Text="Nhập mã voucher hoặc mã kích hoạt" FontSize="12" TextColor="#78909C" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <!-- Nút xác nhận -->
            <Button x:Name="BtnConfirm"
                    Text="XÁC NHẬN THANH TOÁN"
                    BackgroundColor="#29B6F6"
                    TextColor="#0D1B2A"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="14"
                    HeightRequest="52"
                    Margin="0,0,0,12"
                    Clicked="OnConfirmPaymentClicked" />

            <Label Text="🔒 Thanh toán được mã hóa và bảo mật"
                   FontSize="12" TextColor="#546E7A"
                   HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
