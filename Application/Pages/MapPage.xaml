<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp1.Pages.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title=""
    Shell.NavBarIsVisible="False">
    <Grid RowDefinitions="*" ColumnDefinitions="*">
        <maps:Map x:Name="MyMap"
                  MapType="Street"
                  IsShowingUser="False"
                  IsScrollEnabled="True"
                  IsZoomEnabled="True" />

        <!-- ═══════════════ FLOATING SEARCH BAR ═══════════════ -->
        <VerticalStackLayout Margin="12,48,12,0"
                             VerticalOptions="Start"
                             ZIndex="9">

            <!-- Search Bar Row -->
            <Border Padding="10,0"
                    BackgroundColor="White"
                    Stroke="#E6E6E6"
                    StrokeThickness="1">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="26" />
                </Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*,Auto,Auto" HeightRequest="52">
                    <Label Grid.Column="0" Text="🔍" FontSize="18"
                           VerticalOptions="Center" Margin="4,0,4,0" />

                    <!-- Search Entry -->
                    <Entry x:Name="SearchEntry"
                           Grid.Column="1"
                           Placeholder="Tìm địa điểm..."
                           PlaceholderColor="#9E9E9E"
                           TextColor="#1F1F1F"
                           FontSize="15"
                           BackgroundColor="Transparent"
                           VerticalOptions="Center"
                           TextChanged="OnSearchTextChanged"
                           Completed="OnSearchCompleted" />

                    <!-- QR Button -->
                    <Border Grid.Column="2"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#F5F5F5"
                            Stroke="Transparent"
                            Margin="0,0,6,0"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnQrButtonClicked" />
                        </Border.GestureRecognizers>
                        <Label Text="▦" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#3F3F3F" />
                    </Border>

                    <!-- Avatar -->
                    <Border Grid.Column="3"
                            x:Name="AvatarBorder"
                            WidthRequest="36" HeightRequest="36"
                            BackgroundColor="#5C6BC0"
                            Stroke="Transparent"
                            Margin="0,0,2,0"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnTopLoginClicked" />
                        </Border.GestureRecognizers>
                        <Grid>
                            <Image x:Name="ImgAvatar" Aspect="AspectFill" IsVisible="False" WidthRequest="36" HeightRequest="36">
                                <Image.Clip>
                                    <EllipseGeometry Center="18,18" RadiusX="18" RadiusY="18" />
                                </Image.Clip>
                            </Image>
                            <Label x:Name="AvatarLabel" Text="?" TextColor="White" FontSize="15" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Search Suggestions Dropdown -->
            <Border x:Name="SearchDropdown"
                    IsVisible="False"
                    BackgroundColor="White"
                    Stroke="#E6E6E6"
                    StrokeThickness="1"
                    Margin="0,4,0,0">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.12" Offset="0,4" Radius="10" />
                </Border.Shadow>
                <CollectionView x:Name="SearchSuggestions"
                                MaximumHeightRequest="240"
                                SelectionMode="Single"
                                SelectionChanged="OnSuggestionSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="16,12" ColumnDefinitions="Auto,*">
                                <Label Grid.Column="0" Text="📍" FontSize="16" VerticalOptions="Center" Margin="0,0,12,0" />
                                <VerticalStackLayout Grid.Column="1">
                                    <Label Text="{Binding Name}" FontSize="14" TextColor="#202124" FontAttributes="Bold" />
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="#5F6368" MaxLines="1" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Language Bar Row -->
            <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                <Border Grid.Column="0"
                        Padding="10,8"
                        BackgroundColor="White"
                        Stroke="#E6E6E6"
                        StrokeThickness="1"
                        Margin="0,0,8,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Opacity="0.10" Offset="0,2" Radius="6" />
                    </Border.Shadow>
                    <HorizontalStackLayout x:Name="LangBar" Spacing="6">
                        <Border x:Name="BtnVi" Padding="8,4" Background="#1976D2" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇻🇳" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="vi-VN" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnEn" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Label Text="🇺🇸" FontSize="16" />
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="en-US" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Border x:Name="BtnJa" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ja-JP" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <Label Text="🇯🇵" FontSize="16" />
                                <Label Text="🔒" FontSize="8" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-2,-2,0" />
                            </Grid>
                        </Border>
                        <Border x:Name="BtnKo" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="ko-KR" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <Label Text="🇰🇷" FontSize="16" />
                                <Label Text="🔒" FontSize="8" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-2,-2,0" />
                            </Grid>
                        </Border>
                        <Border x:Name="BtnDe" Padding="8,4" Background="#333333" Stroke="#00000000">
                            <Border.StrokeShape><RoundRectangle CornerRadius="8" /></Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnLangTapped" CommandParameter="de-DE" />
                            </Border.GestureRecognizers>
                            <Grid>
                                <Label Text="🇩🇪" FontSize="16" />
                                <Label Text="🔒" FontSize="8" HorizontalOptions="End" VerticalOptions="Start" Margin="0,-2,-2,0" />
                            </Grid>
                        </Border>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </VerticalStackLayout>
        <!-- ═══════════════ END HEADER ═══════════════ -->

        <!-- Location + Zoom buttons -->
        <VerticalStackLayout Grid.Row="0"
                             HorizontalOptions="End"
                             VerticalOptions="Center"
                             Margin="0,130,12,0"
                             Spacing="10"
                             ZIndex="7">
            <Border Background="White" Stroke="#E6E6E6" StrokeThickness="1" WidthRequest="46" HeightRequest="46">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="23" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.16" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <Grid BackgroundColor="Transparent">
                    <Path Data="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7z"
                          Fill="#1A73E8"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="23"
                          HeightRequest="23" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLocateMeClicked" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <Border Background="White" Stroke="#E6E6E6" StrokeThickness="1" WidthRequest="46" HeightRequest="94">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.16" Offset="0,2" Radius="6" />
                </Border.Shadow>
                <Grid RowDefinitions="*,1,*">
                    <Button Grid.Row="0" Text="+" FontSize="20" TextColor="#3C4043" BackgroundColor="Transparent" Padding="0" Clicked="OnZoomInClicked" />
                    <BoxView Grid.Row="1" Color="#ECECEC" />
                    <Button Grid.Row="2" Text="−" FontSize="20" TextColor="#3C4043" BackgroundColor="Transparent" Padding="0" Clicked="OnZoomOutClicked" />
                </Grid>
            </Border>
        </VerticalStackLayout>

        <!-- ═══════════════ BOTTOM SHEET ═══════════════ -->
        <Border x:Name="BottomSheet" Padding="0" Background="Transparent" VerticalOptions="End" ZIndex="10">
            <Border Padding="16,8,16,24" Background="White" Stroke="#E6E6E6">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20,20,0,0" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Opacity="0.14" Offset="0,-3" Radius="12" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="0">
                    <!-- Drag handle -->
                    <Grid Padding="0,6,0,10">
                        <BoxView HeightRequest="4" WidthRequest="46" HorizontalOptions="Center" BackgroundColor="#D0D0D0" CornerRadius="2" />
                        <Grid.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="BottomSheet_PanUpdated" />
                            <TapGestureRecognizer Tapped="BottomSheet_TapHeader" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Media Area: Image Carousel -->
                    <Border Background="#F2F4F8" Stroke="#00000000" Margin="0,0,0,12">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Grid HeightRequest="180">
                            <CarouselView x:Name="PoiImageCarousel"
                                          IndicatorView="PoiImageIndicator"
                                          IsVisible="False"
                                          Loop="False"
                                          HeightRequest="180">
                                <CarouselView.ItemTemplate>
                                    <DataTemplate>
                                        <Image Source="{Binding .}" Aspect="AspectFill" HeightRequest="180" />
                                    </DataTemplate>
                                </CarouselView.ItemTemplate>
                            </CarouselView>
                            <IndicatorView x:Name="PoiImageIndicator"
                                           IndicatorColor="#80FFFFFF"
                                           SelectedIndicatorColor="White"
                                           HorizontalOptions="Center"
                                           VerticalOptions="End"
                                           Margin="0,0,0,6"
                                           IsVisible="False" />
                            <Image x:Name="PoiImage" HeightRequest="180" Aspect="AspectFill" />
                        </Grid>
                    </Border>

                    <!-- Info Area -->
                    <VerticalStackLayout Spacing="3" Margin="0,0,0,14">
                        <Label x:Name="DetailName" FontSize="18" FontAttributes="Bold" TextColor="#202124" />
                        <Label x:Name="DetailCoord" FontSize="12" TextColor="#80868B" />
                        <Label x:Name="DetailDesc" FontSize="13" TextColor="#5F6368" MaxLines="3" LineBreakMode="TailTruncation" Margin="0,4,0,0" />
                    </VerticalStackLayout>

                    <!-- Action Buttons Row -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                        <Button x:Name="BtnDirections"
                                Grid.Column="0"
                                Text="🚙 Đường đi"
                                FontSize="12"
                                Padding="8,10"
                                BackgroundColor="#1976D2"
                                TextColor="White"
                                CornerRadius="12" />
                        <Button x:Name="BtnOpenInMaps"
                                Grid.Column="1"
                                Text="🗺 Maps"
                                FontSize="12"
                                Padding="8,10"
                                BackgroundColor="#F1F3F4"
                                TextColor="#3C4043"
                                CornerRadius="12" />
                        <Button x:Name="BtnListen"
                                Grid.Column="2"
                                Text="🎧 Nghe"
                                FontSize="12"
                                Padding="8,10"
                                BackgroundColor="#00897B"
                                TextColor="White"
                                CornerRadius="12" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Border>
    </Grid>
</ContentPage>
