@startuml sequence-narration-queue
title NarrationManager — Queue nội bộ + Worker Loop
skinparam defaultFontSize 11

participant "NarrationHandler" as H
participant "NarrationManager" as Nar
participant "WorkerLoop"       as W
participant "Audio/TTS"        as Audio

H -> Nar : HandleAsync(announcement)
Nar -> Nar : IsDuplicate? key=poi:event:lang, window=2s
alt Trùng lặp → skip
else
  Nar -> Nar : Winner-only check\n(so sánh PriorityLevel với queue)
  alt POI khác có PriorityLevel cao hơn
    Nar --> H : return (loser discarded)
  else Thắng → xóa losers, enqueue
    Nar -> Nar : Enqueue, sort: Tap(1) > Enter(2) > Near(3)
    W -> W     : Dequeue next item
    alt AudioUrl có sẵn
      W -> Audio : PlayFileAsync(audioUrl)
    else TTS fallback
      W -> Audio : SpeakAsync(text) — chia câu . ! ?
    end
    Audio --> W : Completed / Cancelled
    W -> H      : Completion resolved
  end
end

== Stop() ==
H -> Nar  : Stop()
Nar -> Nar : Clear queue, Cancel current
Nar -> Audio : Stop()
@enduml
