@startuml usecase-system
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 11

actor Guest  as "Guest"
actor User   as "User\n(Registered)"
actor Pro    as "PRO User"
actor Admin  as "Admin"
actor Web    as "Web Browser"

rectangle "GpsGeoFenceApp" {
  (Track GPS\nFG/BG)         as UC1
  (Map + POI\nNearby)        as UC2
  (Auto Narration\nEnter/Near/Tap) as UC3
  (Scan QR)                  as UC4
  (Freemium\nQuota Check)    as UC7
  (Upgrade Plan)             as UC8
  (Travel History)           as UC9
  (Directions)               as UC10
  (Web Landing\nNarration×3) as UC11
  (Download APK)             as UC12
  (Manage POI/Tour/QR)       as UC13
  (Manage Users\n& Devices)  as UC15
  (Analytics\nDashboard)     as UC17
  (Conflict Policy\n& AudioMode) as UC18
}

Guest --> UC1 ; Guest --> UC2 ; Guest --> UC3
Guest --> UC4 ; Guest --> UC7 ; Guest --> UC8 ; Guest --> UC11
User --|> Guest ; User --> UC9
Pro  --|> User  ; Pro  --> UC10
Web  --> UC11   ; Web  --> UC12
Admin --> UC13 ; Admin --> UC15 ; Admin --> UC17 ; Admin --> UC18

UC3  ..> UC1  : <<include>>
UC3  ..> UC7  : <<include>>
UC4  ..> UC7  : <<include>>
UC11 ..> UC12 : <<extend>>\nquota exceeded
@enduml
