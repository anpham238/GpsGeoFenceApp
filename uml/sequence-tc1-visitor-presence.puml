@startuml sequence-tc1-visitor-presence
title TC1 — Visitor Management: n thiết bị → OnlineCount & TotalConnectionCount
skinparam defaultFontSize 11

actor "Device 1" as D1
actor "Device N" as DN
participant "DeviceHub\n(SignalR)" as Hub
participant "DevicePresenceService" as P
database "GuestDevices" as DB
participant "Admin Web" as Admin

D1 -> Hub : Connect(?deviceId=DEV-001)
Hub -> P  : MarkConnected("DEV-001", connId)
note right of P
  OnlineCount = 1
  TotalConnectionCount = 1
end note
Hub -> DB    : Upsert GuestDevice
Hub -> Admin : { onlineCount:1, totalConnectionCount:1 }
Admin -> Admin : devStatOnline=1, devStatConnections=1

...n thiết bị kết nối...

DN -> Hub : Connect(?deviceId=DEV-N)
Hub -> P  : MarkConnected("DEV-N", connId)
note right of P
  OnlineCount = N        (unique devices)
  TotalConnectionCount = N×k (k sessions/device)
end note
Hub -> Admin : { onlineCount:N, totalConnectionCount:N×k }

Admin -> Hub : GET /api/v1/admin/devices/realtime-snapshot
Hub --> Admin : { onlineCount, totalConnectionCount, devices[] }
Admin -> Admin : Render 4 stat tiles
@enduml
